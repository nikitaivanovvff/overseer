%% Overseer — high-level architecture
%% How the TUI, the daemon, and the AI harnesses fit together, starting from
%% the terminal application the user is actually sitting in.
%% Render: mmdc -i docs/architecture.mmd -o architecture.svg  (or any mermaid viewer)

flowchart TB
    subgraph TERM["Terminal application (Kaku / iTerm2 / kitty / ...)"]
        USER(("User"))
        subgraph TUI["overseer TUI  (alt-screen ratatui app, detachable attach client)"]
            TREE["Agent structure pane<br/>(tree of roots + children)"]
            PANE["Agent pane<br/>(selected agent's live terminal)"]
            DETAILS["Details pane<br/>(task · repo · branch · status · ctx%)"]
            FOOTER["Footer<br/>(fleet summary · hotkeys · messages)"]
        end
    end

    USER -- "keys · mouse clicks · wheel" --> TUI

    subgraph DAEMON["overseer daemon  (background, one per user, owns all state)"]
        IPC["IPC server<br/>Unix socket, newline-delimited JSON<br/>one-shot requests + attach streams"]
        REG["AgentRegistry<br/>(in-memory tree + status,<br/>broadcast of registry events)"]
        SM["SessionManager<br/>(one PTY + in-process terminal<br/>emulator per agent, 10k-line scrollback)"]
    end

    TUI <-- "attach: Watch/Write/Resize/Scroll →<br/>← Snapshot · StatusChanged · Output (GridSnapshot)" --> IPC
    CLI["overseer &lt;subcommand&gt;<br/>(status · spawn · list · prompt · ...)"] -- "one-shot request" --> IPC
    IPC --> REG
    IPC --> SM

    subgraph AGENTS["Agent sessions (each its own PTY child process)"]
        ROOT["Workspace — one per repo<br/>bare shell or picked harness"]
        C1["Child agent<br/>(claude)"]
        C2["Child agent<br/>(opencode / pi)"]
    end

    SM -- "spawn PTY, inject OVERSEER_* env,<br/>write keystrokes, read output" --> AGENTS
    ROOT -- "overseer spawn --task ..." --> CLI
    C1 & C2 -. "worktree/branch isolation<br/>(the agent's job, not Overseer's)" .-> REPO[("git repository")]

    subgraph HARNESS["Harness integration (installed once per user by 'overseer install')"]
        HOOKS["claude: settings.json hooks<br/>opencode: plugin.js<br/>pi: --extension"]
        SKILLS["role skills / instructions<br/>(root may spawn, child may not)"]
    end

    AGENTS -- "lifecycle events fire hooks" --> HOOKS
    HOOKS -- "overseer status &lt;s&gt;" --> CLI
    SKILLS -.-> AGENTS

    %% What the user sees, closing the loop
    REG -- "registry events" --> TREE
    SM -- "rendered GridSnapshot<br/>(never raw PTY bytes)" --> PANE
